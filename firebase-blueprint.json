{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "An AI-powered poster project.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ANALYZED", "GENERATED", "DNA MAPPED"] },
        "imageUrl": { "type": "string" },
        "tokens": { "type": "number" },
        "quality": { "type": "string" },
        "layers": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["title", "createdAt", "updatedAt", "status", "imageUrl", "userId"]
    },
    "BrandIdentity": {
      "title": "Brand Identity",
      "description": "A stylistic identity used for brand memory.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tags", "imageUrl", "colors", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of poster projects."
    },
    "/identities/{identityId}": {
      "schema": "BrandIdentity",
      "description": "Collection of brand stylistic identities."
    }
  }
}
